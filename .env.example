# ═══════════════════════════════════════════════════════════════════
# FastDrop — Environment Variables Example
# Copy this file: cp .env.example .env
# Then fill in your actual API keys.
# ⚠️  NEVER commit the real .env file to Git!
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# [1] GROQ — Primary Arabic LLM (Llama 4 Maverick)
#     Free: ~500 req/day (no credit card required)
#     Get:  console.groq.com → API Keys
# ─────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY_HERE

# ─────────────────────────────────────────────────────────────────
# [2] GEMINI — Text-to-SQL Analytics + Arabic Fallback
#     Free: 250 req/day for gemini-2.5-flash (no credit card)
#     Get:  aistudio.google.com → Get API Key
# ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_KEY_HERE

# ─────────────────────────────────────────────────────────────────
# [3] HUGGINGFACE — Embeddings + Fallback LLMs (Qwen 2.5-72B)
#     Free: ~1,000 req/day (no credit card required)
#     Get:  huggingface.co → Settings → Access Tokens
# ─────────────────────────────────────────────────────────────────
HUGGINGFACE_API_TOKEN=hf_YOUR_HUGGINGFACE_TOKEN_HERE

# ─────────────────────────────────────────────────────────────────
# [4] OPENROUTER — Emergency LLM Fallback
#     Free models available (e.g., gemini-2.0-flash-exp:free)
#     Get:  openrouter.ai → API Keys
# ─────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# ─────────────────────────────────────────────────────────────────
# [5] TELEGRAM — Bot Token (100% free, unlimited messages)
#     Get:  Telegram → @BotFather → /newbot → copy the token
# ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# ─────────────────────────────────────────────────────────────────
# [6] GOOGLE MAPS — Live Traffic & Routing (needs billing enabled)
#     Free: 10,000 req/month then pay-as-you-go
#     Get:  console.cloud.google.com → APIs & Services
#     Alternative (free, no card): openrouteservice.org
# ─────────────────────────────────────────────────────────────────
GOOGLE_MAPS_KEY=AIzaSy_YOUR_GOOGLE_MAPS_KEY_HERE

# ─────────────────────────────────────────────────────────────────
# [7] OPENCAGE — Geocoding Fallback
#     Free: 2,500 req/day (no credit card required)
#     Get:  opencagedata.com → Dashboard
# ─────────────────────────────────────────────────────────────────
OPENCAGE_API_KEY=YOUR_OPENCAGE_API_KEY_HERE

# ─────────────────────────────────────────────────────────────────
# [8] DATABASE
#     Leave empty to use SQLite (auto-created, zero config).
#     For PostgreSQL: install it, create a DB called 'fastdrop',
#     then fill in your credentials below.
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/fastdrop
# DATABASE_URL=                    # ← uncomment & leave blank for SQLite

# ─────────────────────────────────────────────────────────────────
# [9] REDIS — Semantic Cache + Rate-Limiting
#     Install Redis locally or run: docker run -p 6379:6379 -d redis
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────────
# [10] APPLICATION SETTINGS
# ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS
DEBUG=False
DEFAULT_LANGUAGE=ar             # ar = Arabic (default) | en = English
SUPPORTED_LANGUAGES=ar,en
DOMAIN=localhost

# ─────────────────────────────────────────────────────────────────
# [11] LANGSMITH — LLM Observability & Tracing (optional)
#     Free tier available.
#     Get:  smith.langchain.com → Settings → API Keys
# ─────────────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_YOUR_LANGSMITH_KEY_HERE
LANGCHAIN_PROJECT=FastDrop_Development
